2. Data Retrieval (Very Important)
SELECT Statement
SELECT * FROM customers;
Filtering Data
SELECT *
FROM customers
WHERE city='Hyderabad';
Operators
AND
OR
NOT
IN
BETWEEN
LIKE
EXISTS
SELECT *
FROM employees
WHERE salary > 50000
AND department='IT';
3. Sorting & Limiting Data
ORDER BY
SELECT *
FROM employees
ORDER BY salary DESC;
TOP / LIMIT
SELECT TOP 10 *
FROM employees;
4. Aggregate Functions (Most Asked)
Functions
COUNT()
SUM()
AVG()
MIN()
MAX()
SELECT
COUNT(*) AS total_customers,
AVG(salary) AS avg_salary
FROM employees;
5. GROUP BY & HAVING (Critical)
GROUP BY
SELECT department,
COUNT(*)
FROM employees
GROUP BY department;
HAVING
SELECT department,
AVG(salary)
FROM employees
GROUP BY department
HAVING AVG(salary) > 50000;
6. Joins (Highest Priority)
INNER JOIN
SELECT c.customer_name,
o.order_amount
FROM customers c
INNER JOIN orders o
ON c.customer_id=o.customer_id;
Types of Joins
INNER JOIN
LEFT JOIN
RIGHT JOIN
FULL JOIN
SELF JOIN
CROSS JOIN
7. Subqueries
Single Row Subquery
SELECT *
FROM employees
WHERE salary >
(
SELECT AVG(salary)
FROM employees
);
Correlated Subquery
SELECT *
FROM employees e
WHERE salary >
(
SELECT AVG(salary)
FROM employees
WHERE department=e.department
);
8. Common Table Expressions (CTE)

Very important in interviews.

WITH Sales_CTE AS
(
SELECT *
FROM sales
)
SELECT *
FROM Sales_CTE;
9. Window Functions (Most Important for Data Engineers)
ROW_NUMBER()
SELECT *,
ROW_NUMBER() OVER
(PARTITION BY department
ORDER BY salary DESC) rn
FROM employees;
Other Window Functions
